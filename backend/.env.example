# --- AI 默认值（可选；应用启动后可在 UI 右上角"设置"中修改并覆盖）---
AI_PROVIDER=deepseek
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com/v1
AI_MODEL=deepseek-chat

# --- 数据源 ---
DATASOURCE_PRIMARY=akshare
TUSHARE_TOKEN=

# --- 同步 ---
SYNC_ENABLED=true
SYNC_CRON_HOUR=16
SYNC_CRON_MINUTE=10

# --- 应用 ---
APP_LOG_LEVEL=INFO
DB_PATH=/app/data/app.db
